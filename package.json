{
  "name": "e-commerce-livros-backend",
  "version": "1.0.0",
  "description": "Backend E-commerce de Livros - LES 2026",
  "main": "index.js",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/jest": "^30.0.0",
    "@types/node": "^8.0.29",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.3.0",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.8.2"
  },
  "dependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "mysql": "^2.14.1",
    "pg": "^8.14.1",
    "reflect-metadata": "^0.1.13",
    "typeorm": "^0.3.27",
    "uuid": "^11.1.0"
  },
  "scripts": {
    "dev": "ts-node-dev src/server.ts",
    "start": "ts-node src/index.ts",
    "typeorm": "ts-node-dev ./node_modules/typeorm/cli.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "migration:generate": "yarn typeorm migration:generate ./src/database/migrations/auto-migration -d ./src/database/index.ts",
    "migration:create": "yarn typeorm migration:create ./src/database/migrations/new-migration",
    "migration:run": "yarn typeorm migration:run -d ./src/database/index.ts",
    "migration:revert": "yarn typeorm migration:revert -d ./src/database/index.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  }
}
